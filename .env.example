# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# DashScope API Key (from https://dashscope.console.aliyun.com/)
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# DashScope API Base URL
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# Qwen Model to use
QWEN_MODEL=qwen-turbo

# ─────────────────────────────────────────────
# Productivity Integrations (Optional)
# ─────────────────────────────────────────────

# GitHub Token (from https://github.com/settings/tokens)
# Used for: /github, /repo, /issue, /gitsearch
GITHUB_TOKEN=your_github_token_here

# Notion Token (from https://www.notion.so/my-integrations)
# Used for: /notion, /notionpage
NOTION_TOKEN=your_notion_token_here

# Notion Database ID (for creating pages)
# Get from any Notion database URL
NOTION_DATABASE_ID=your_notion_database_id_here

# Image Generation - Uses Alibaba Wanx (configured in DASHSCOPE_API_KEY)
# Available models from your API:
#   - wan2.7-image-pro (Best quality)
#   - wan2.7-image (Standard)
#   - qwen-image-plus (Alternative)
#   - qwen-image-max (Premium)
IMAGE_MODEL=wan2.7-image-pro

# OpenAI API Key (optional - not needed if using Alibaba Wanx)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API Key (optional - not needed if using Alibaba Wanx)
GEMINI_API_KEY=your_gemini_api_key_here

# ─────────────────────────────────────────────
# Admin & Bot Settings
# ─────────────────────────────────────────────

# Admin User IDs (comma-separated, get from @userinfobot)
ADMIN_IDS=123456789

# Rate Limit (seconds between messages)
RATE_LIMIT_SECONDS=3

# Max Conversation History (messages per user)
MAX_HISTORY=10

# Webhook URL (leave empty for polling mode)
WEBHOOK_URL=

# Render/Heroku API Key (for CLI restart)
RENDER_API_KEY=

# Render Service ID (for CLI restart)
RENDER_SERVICE_ID=
